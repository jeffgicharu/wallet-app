    {
      "description": "a deposit of 5000 KES with a fresh idempotency key",
      "providerState": "alice exists with balance 50000 KES",
      "request": {
        "body": {
          "amount": 5000,
          "idempotencyKey": "dep-pact-001"
        },
        "headers": {
          "Authorization": "Bearer test.jwt.token",
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.headers.Authorization": {
            "match": "regex",
            "regex": "^Bearer .+"
          }
        },
        "method": "POST",
        "path": "/api/wallet/deposit"
      },
      "response": {
        "body": {
          "data": {
            "amount": 5000,
            "createdAt": "2026-05-08T09:00:00Z",
            "reference": "DEP-dep-pact-001",
            "status": "COMPLETED",
            "type": "DEPOSIT"
          },
          "message": "Deposit successful",
          "success": true,
          "timestamp": "2026-05-08T09:00:00Z"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.body.data.createdAt": {
            "match": "type"
          },
          "$.body.data.reference": {
            "match": "type"
          },
          "$.body.message": {
            "match": "type"
          },
          "$.body.timestamp": {
            "match": "type"
          }
        },
        "status": 200
      }
    },
